# Git attributes configuration
# Define how Git should handle different file types

# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts
*.sh text eol=lf
*.zsh text eol=lf
*.bash text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Config files
.gitconfig text eol=lf
.gitignore text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Binary files
*.jpg binary
*.png binary
*.gif binary
*.zip binary
*.tar binary
